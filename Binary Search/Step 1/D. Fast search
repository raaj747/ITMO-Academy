#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;
using vll = vector<long long>;

int main()
{
    int n;
    cin>>n;

    vll a(n);
    for(int i=0;i<n;i++)
    {
        cin>>a[i];
    }

    sort(a.begin(), a.end());

    int k;
    cin>>k;

    while(k--)
    {
        ll l,r;
        cin>>l>>r;

        auto left=lower_bound(a.begin(),a.end(),l);

        auto right=upper_bound(a.begin(),a.end(),r);

        cout<<(right-left)<<" ";
    }

}



