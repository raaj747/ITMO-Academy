#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;

int main()
{
    int n,k;
    cin>>n>>k;

    vector<ll> a(n);
    for(int i=0;i<n;i++)
    {
        cin>>a[i];
    }

    while(k--)
    {
        ll x;
        cin>>x;

        auto it=lower_bound(a.begin(),a.end(),x);

        if(it==a.end())
        {
            cout<<n+1<<nl;
        }
        else
        {
            cout<<(it-a.begin()+1)<<nl;
        }


    }

}


