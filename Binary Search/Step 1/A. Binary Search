#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;

int main()
{

    int n,k;
    cin>>n>>k;

    vector<ll> a(n);
    for(int i=0;i<n;i++)
    {
        cin>>a[i];
    }

    while(k--)
    {
        ll x;
        cin>>x;

        int left=0,right=n-1;

        bool found=false;

        while(left<=right)
        {
            int mid=left+(right-left)/2;

            if(a[mid]==x)
            {
                found=true;
                break;
            }
            else if(a[mid]<x)
            {
                left=mid+1;
            }
            else
            {
                right=mid-1;
            }
        }

        if(found)
        {
            cout<<"YES"<<nl;
        }
        else
        {
            cout<<"NO"<<nl;
        }





    }




}

