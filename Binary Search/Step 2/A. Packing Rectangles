#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;
using vll = vector<long long>;

int main()
{

    ll w,h,n;
    cin>>w>>h>>n;

    ll l=0;
    ll r=1;

    while((r/w)*(r/h)< n)
    {
        r*=2;
    }

    while(r-l>1)
    {
        ll mid=(l+r)/2;

        if((mid/w)*(mid/h)>=n)
        {
            r=mid;
        }
        else
        {
            l=mid;
        }


    }

    cout<<r<<nl;


}


